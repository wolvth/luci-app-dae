#!/bin/sh

readonly NAME="dae"
readonly PROG="/usr/bin/dae"
readonly CONF="/etc/dae/config.dae"
readonly LOG="/var/log/dae/dae.log"
readonly LOG_DIR="/var/log/dae"
readonly CONF_DIR="/etc/dae"
readonly INSTALLER="/usr/share/dae/installer.sh"
readonly ACTIONS_SCRIPT="/root/sh/updae_from_actions.sh"
readonly GEO_LOCK="/var/run/dae-geo-update.lock"
readonly DAE_LOCK="/var/run/dae-update.lock"
readonly GEOIP="/usr/share/dae/geoip.dat"
readonly GEOSITE="/usr/share/dae/geosite.dat"
readonly DAE_FAIL="${DAE_LOCK}.failed"
readonly GEO_FAIL="${GEO_LOCK}.failed"

. /lib/functions.sh
. /usr/share/libubox/jshn.sh

# ── 确保目录和文件存在 ─────────────────────────────────────
ensure_directories() {
    [ ! -d "$LOG_DIR" ] && mkdir -p "$LOG_DIR"
    [ ! -d "$CONF_DIR" ] && mkdir -p "$CONF_DIR"
    [ ! -f "$LOG" ] && touch "$LOG" && chmod 644 "$LOG"
    [ ! -f "$CONF" ] && touch "$CONF" && chmod 600 "$CONF"
}

# ── 确保 UCI 配置存在 ──────────────────────────────────────
[ ! -f /etc/config/dae ] && touch /etc/config/dae
ensure_uci_config() {
    if ! uci -q get dae.config >/dev/null 2>&1; then
        uci set dae.config=config
        uci set dae.config.enabled='1'
        uci set dae.config.config_file='/etc/dae/config.dae'
        uci set dae.config.disable_waiting_network='0'
        uci set dae.config.enable_dae_log='1'
        uci set dae.config.log_maxbackups='1'
        uci set dae.config.log_maxsize='3'
        uci commit dae
    fi
}

# ── 检查 dae 二进制 ────────────────────────────────────────
check_dae_binary() {
    [ -f "$PROG" ] && [ -x "$PROG" ]
}

# ── 基础工具函数 ───────────────────────────────────────────
is_enabled() { "/etc/init.d/${1}" enabled; }
is_running() {
    [ "$(ubus call service list "{ 'name': '$1' }" | \
        jsonfilter -q -e "@['$1'].instances[*].running" | head -1)" = 'true' ]
}
get_version() { "$PROG" --version 2>/dev/null | awk 'NR==1{print $3}'; }
print_json_bool() { json_init; json_add_boolean "$1" "$2"; json_dump; json_cleanup; }

# ── 进程资源监控 ───────────────────────────────────────────
get_process_stats() {
    local pid rss_kb vm_kb cpu_pct uptime_str threads
    pid="$(pidof dae 2>/dev/null | awk '{print $1}')"

    if [ -z "$pid" ] || [ ! -d "/proc/$pid" ]; then
        json_init
        json_add_boolean 'running' '0'
        json_add_string 'cpu_percent' '0'
        json_add_string 'mem_rss_kb' '0'
        json_add_string 'mem_rss_mb' '0'
        json_add_string 'mem_vsz_kb' '0'
        json_add_string 'mem_vsz_mb' '0'
        json_add_string 'threads' '0'
        json_add_string 'uptime' '-'
        json_add_int 'pid' 0
        json_dump
        json_cleanup
        return
    fi

    local stat_fields clk_tck
    clk_tck="$(getconf CLK_TCK 2>/dev/null || echo 100)"
    local prev_file="/tmp/dae-stats-prev"

    stat_fields="$(cat /proc/$pid/stat 2>/dev/null)"
    if [ -n "$stat_fields" ]; then
        local utime stime num_threads start_time system_uptime
        utime="$(echo "$stat_fields" | awk '{print $14}')"
        stime="$(echo "$stat_fields" | awk '{print $15}')"
        num_threads="$(echo "$stat_fields" | awk '{print $20}')"
        start_time="$(echo "$stat_fields" | awk '{print $22}')"
        system_uptime="$(cat /proc/uptime 2>/dev/null | awk '{printf "%d", $1}')"

        # 瞬时 CPU：本次采样 - 上次采样
        local prev_utime prev_stime prev_uptime
        if [ -f "$prev_file" ]; then
            prev_utime="$(awk '{print $1}' "$prev_file")"
            prev_stime="$(awk '{print $2}' "$prev_file")"
            prev_uptime="$(awk '{print $3}' "$prev_file")"
        fi
        prev_utime="${prev_utime:-0}"
        prev_stime="${prev_stime:-0}"
        prev_uptime="${prev_uptime:-0}"

        # 首次采样记录基线，CPU 返回 0
        if [ ! -f "$prev_file" ] || [ "$prev_uptime" -eq 0 ]; then
            printf '%s %s %s\n' "$utime" "$stime" "$system_uptime" > "$prev_file"
            cpu_pct=0
        else
            printf '%s %s %s\n' "$utime" "$stime" "$system_uptime" > "$prev_file"

            local delta_cpu delta_time num_cpu
            delta_cpu=$(( (utime - prev_utime) + (stime - prev_stime) ))
            delta_time=$(( (system_uptime - prev_uptime) * clk_tck ))
            num_cpu=$(nproc 2>/dev/null || grep -c '^processor' /proc/cpuinfo 2>/dev/null || echo 1)
            if [ "$delta_time" -gt 0 ]; then
                cpu_pct=$(( delta_cpu * 100 / delta_time / num_cpu ))
                [ "$cpu_pct" -gt 100 ] && cpu_pct=100
                [ "$cpu_pct" -lt 0 ] && cpu_pct=0
            else
                cpu_pct=0
            fi
        fi

        if [ "$start_time" -gt 0 ] && [ "$system_uptime" -gt 0 ]; then
            local run_secs days hours mins secs
            run_secs=$((system_uptime - start_time / clk_tck))
            [ "$run_secs" -lt 0 ] && run_secs=0
            days=$((run_secs / 86400))
            hours=$(((run_secs % 86400) / 3600))
            mins=$(((run_secs % 3600) / 60))
            secs=$((run_secs % 60))
            if [ "$days" -gt 0 ]; then
                uptime_str="${days}d ${hours}h ${mins}m"
            elif [ "$hours" -gt 0 ]; then
                uptime_str="${hours}h ${mins}m ${secs}s"
            else
                uptime_str="${mins}m ${secs}s"
            fi
        else
            uptime_str="-"
        fi
        threads="${num_threads:-0}"
    else
        cpu_pct=0; threads=0; uptime_str="-"
    fi

    # 内存
    rss_kb=0; vm_kb=0
    if [ -f "/proc/$pid/status" ]; then
        rss_kb="$(awk '/^VmRSS:/{print $2}' /proc/$pid/status 2>/dev/null || echo 0)"
        vm_kb="$(awk '/^VmSize:/{print $2}' /proc/$pid/status 2>/dev/null || echo 0)"
    fi
    rss_kb="${rss_kb:-0}"; vm_kb="${vm_kb:-0}"
    local rss_mb vm_mb
    rss_mb="$((rss_kb / 1024))"
    vm_mb="$((vm_kb / 1024))"

    json_init
    json_add_boolean 'running' '1'
    json_add_int 'pid' "$pid"
    json_add_string 'cpu_percent' "$cpu_pct"
    json_add_string 'mem_rss_kb' "$rss_kb"
    json_add_string 'mem_rss_mb' "$rss_mb"
    json_add_string 'mem_vsz_kb' "$vm_kb"
    json_add_string 'mem_vsz_mb' "$vm_mb"
    json_add_string 'threads' "$threads"
    json_add_string 'uptime' "$uptime_str"
    json_dump
    json_cleanup
}

# ── 获取服务状态 ───────────────────────────────────────────
get_init_status() {
    local name="$1"
    local version
    version="$(get_version)"
    json_init
    json_add_object "$name"
    if is_enabled "$name"; then
        json_add_boolean 'enabled' '1'
    else
        json_add_boolean 'enabled' '0'
    fi
    if is_running "$name"; then
        json_add_boolean 'running' '1'
    else
        json_add_boolean 'running' '0'
    fi
    json_add_string 'version' "$version"
    if [ -f "$GEO_LOCK" ]; then
        json_add_boolean 'geo_updating' '1'
    else
        json_add_boolean 'geo_updating' '0'
    fi
    if [ -f "$DAE_LOCK" ]; then
        json_add_boolean 'dae_updating' '1'
    else
        json_add_boolean 'dae_updating' '0'
    fi
    local dae_failed=0 geo_failed=0
    [ -f "$DAE_FAIL" ] && dae_failed=1
    [ -f "$GEO_FAIL" ] && geo_failed=1
    json_add_boolean 'dae_update_failed' "$dae_failed"
    json_add_boolean 'geo_update_failed' "$geo_failed"
    local geoip_mtime=0 geosite_mtime=0
    [ -f "$GEOIP" ]    && geoip_mtime="$(date -r "$GEOIP" +%s 2>/dev/null || echo 0)"
    [ -f "$GEOSITE" ]  && geosite_mtime="$(date -r "$GEOSITE" +%s 2>/dev/null || echo 0)"
    json_add_int 'geoip_mtime' "$geoip_mtime"
    json_add_int 'geosite_mtime' "$geosite_mtime"
    json_close_object
    json_dump
    json_cleanup
}

# ── 服务操作 ───────────────────────────────────────────────
set_init_action() {
    local name="$1" action="$2"
    [ "$name" = "$NAME" ] || { print_json_bool "result" '0'; return; }

    case "$action" in
        enable|disable|start|stop|restart)
            # 启动/重启前检查二进制和配置文件	
            ensure_directories
            ensure_uci_config
            if [ "$action" = "start" ] || [ "$action" = "restart" ]; then
                if ! check_dae_binary; then
                    if [ -x "$INSTALLER" ]; then
                        sh "$INSTALLER" install-prerelease >> "$LOG" 2>&1
                    fi
                fi
            fi
            if /etc/init.d/"$name" "$action" >/dev/null 2>&1; then
                print_json_bool "result" '1'
            else
                print_json_bool "result" '0'
            fi
            ;;
        # --- 只保存配置，不触发 dae reload ---
        reload_config)
            print_json_bool "result" "1"
            ;;
        update)
            if [ -f "$DAE_LOCK" ]; then
                print_json_bool "result" '0'; return
            fi
            rm -f "$DAE_FAIL"
            ( touch "$DAE_LOCK"
			# ---- 版本感知更新逻辑 ----
              current_ver=$("$PROG" --version 2>/dev/null | awk 'NR==1{print $3}')
              case "$current_ver" in
                  unstable-*|dev-*|nightly-*|snapshot-*|ci-*)
                      if [ -f "$ACTIONS_SCRIPT" ] && [ -x "$ACTIONS_SCRIPT" ]; then
                          sh "$ACTIONS_SCRIPT" >> "$LOG" 2>&1
                      else
                          echo "[update] Actions 版本但 $ACTIONS_SCRIPT 不存在" >> "$LOG"
                          echo "[update] 回退到 installer.sh" >> "$LOG"
                          sh "$INSTALLER" install-prerelease >> "$LOG" 2>&1
                      fi
                      ;;
                  *)
                      sh "$INSTALLER" install-prerelease >> "$LOG" 2>&1
                      ;;
              esac
              rc=$?
              rm -f "$DAE_LOCK"
              [ $rc -eq 0 ] || touch "$DAE_FAIL" ) &
            print_json_bool "result" '1'
            ;;
        update_geo)
            if [ -f "$GEO_LOCK" ]; then
                print_json_bool "result" '0'; return
            fi
            rm -f "$GEO_FAIL"
            ( touch "$GEO_LOCK"
              sh "$INSTALLER" update-geoip >> "$LOG" 2>&1
              rc=$?
              if [ $rc -eq 0 ]; then
                  sh "$INSTALLER" update-geosite >> "$LOG" 2>&1
                  rc=$?
              fi
              rm -f "$GEO_LOCK"
              [ $rc -eq 0 ] || touch "$GEO_FAIL" ) &
            print_json_bool "result" '1'
            ;;
        *)
            print_json_bool "result" '0'
            ;;
    esac
}

# ── 配置校验 ───────────────────────────────────────────────
validate_config() {
    local content="$1" out rc tmp

    if ! check_dae_binary; then
        json_init
        json_add_boolean 'valid' '0'
        json_add_string 'message' 'dae binary not found at /usr/bin/dae'
        json_dump; json_cleanup; return
    fi

    tmp="/tmp/dae-validate-$$.dae"
    if [ -n "$content" ]; then
        printf '%s' "$content" > "$tmp"
    else
        cp "$CONF" "$tmp" 2>/dev/null
    fi
    chmod 600 "$tmp"
    out="$("$PROG" validate -c "$tmp" 2>&1)"
    rc=$?
    rm -f "$tmp"
    json_init
    if [ $rc -eq 0 ]; then
        json_add_boolean 'valid' '1'
        json_add_string 'message' 'Config is valid'
    else
        json_add_boolean 'valid' '0'
        json_add_string 'message' "$out"
    fi
    json_dump
    json_cleanup
}

# ── 内核兼容性检查 ─────────────────────────────────────────
check_kernel_compat() {
    local kver kmaj kmin kver_ok
    kver="$(uname -r | cut -d. -f1-2)"
    kmaj="$(echo "$kver" | cut -d. -f1)"
    kmin="$(echo "$kver" | cut -d. -f2)"
    kver_ok=0
    [ "$kmaj" -gt 5 ] && kver_ok=1
    [ "$kmaj" -eq 5 ] && [ "$kmin" -ge 17 ] && kver_ok=1

    sys_check() { [ -e "$1" ] && echo "1" || echo "0"; }

    kmod_check() {
        lsmod 2>/dev/null | grep -q "^${1} " && echo "1" && return
        [ -d "/sys/module/${1}" ] && echo "1" && return
        find /lib/modules/"$(uname -r)" -name "${1}.ko" 2>/dev/null | grep -q . && echo "1" && return
        echo "0"
    }

    json_init
    json_add_string  "kernel_version"    "$(uname -r)"
    json_add_boolean "kernel_version_ok" "$kver_ok"
    json_add_int "BPF_SYSCALL"        "$(sys_check /sys/fs/bpf)"
    json_add_int "DEBUG_INFO_BTF"     "$(sys_check /sys/kernel/btf/vmlinux)"
    json_add_int "NET_CLS_BPF"        "$(kmod_check cls_bpf)"
    json_add_int "NET_SCH_INGRESS"    "$(kmod_check sch_ingress)"
    json_add_int "CGROUPS"            "$(sys_check /sys/fs/cgroup/cgroup.controllers)"
    local kprobes_ok=0
    [ -e /sys/kernel/tracing/kprobe_events ] && kprobes_ok=1
    [ -e /sys/kernel/debug/tracing/kprobe_events ] && kprobes_ok=1
    json_add_int "KPROBES" "$kprobes_ok"
    json_add_int "kmod_veth"              "$(kmod_check veth)"
    json_add_int "kmod_sched_bpf"         "$(kmod_check cls_bpf)"
    json_add_int "kmod_sched_core"        "$(kmod_check sch_ingress)"
    json_add_int "kmod_xdp_sockets_diag"  "$(kmod_check xsk_diag)"
    local nft_bridge_ok=0
    [ -d /sys/module/nft_bridge ] && nft_bridge_ok=1
    ls /lib/modules/"$(uname -r)"/nft_*bridge*.ko >/dev/null 2>&1 && nft_bridge_ok=1
    json_add_int "kmod_nft_bridge"        "$nft_bridge_ok"
    local ip_forward=0
    [ "$(cat /proc/sys/net/ipv4/ip_forward 2>/dev/null)" = "1" ] && ip_forward=1
    json_add_boolean "ip_forward" "$ip_forward"
    local nft_ok=0
    command -v nft >/dev/null 2>&1 && nft_ok=1
    json_add_boolean "nft" "$nft_ok"
    local mem_free=0
    mem_free="$(awk '/MemAvailable/{print $2}' /proc/meminfo 2>/dev/null || echo 0)"
    json_add_int "mem_free_kb" "$mem_free"
    json_dump
    json_cleanup
}

# ── ubus 入口 ──────────────────────────────────────────────
case "$1" in
    list)
        json_init
        json_add_object "getInitStatus"
            json_add_string 'name' "name"
        json_close_object
        json_add_object "setInitAction"
            json_add_string 'name' "name"
            json_add_string 'action' "action"
        json_close_object
        json_add_object "validateConfig"
            json_add_string 'content' "content"
        json_close_object
        json_add_object "checkKernelCompat"
        json_close_object
        json_add_object "getProcessStats"
        json_close_object
        json_dump
        json_cleanup
        ;;
    call)
        case "$2" in
            getInitStatus)
                read -r input
                json_load "$input"
                json_get_var name 'name'
                json_cleanup
                get_init_status "$name"
                ;;
            setInitAction)
                read -r input
                json_load "$input"
                json_get_var name "name"
                json_get_var action "action"
                json_cleanup
                set_init_action "$name" "$action"
                ;;
            validateConfig)
                read -r input
                json_load "$input"
                json_get_var content 'content'
                json_cleanup
                validate_config "$content"
                ;;
            checkKernelCompat)
                check_kernel_compat
                ;;
            getProcessStats)
                get_process_stats
                ;;
        esac
        ;;
esac
